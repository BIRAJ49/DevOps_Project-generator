JWT_SECRET_KEY=replace-with-a-32-character-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://username:password@host:5432/devops_project_generator
